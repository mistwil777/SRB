# Copier ce fichier en .env et adapter les valeurs
# Ne jamais committer .env

INFLUXDB_TOKEN=srb-local-dev-token-change-in-prod
INFLUXDB_URL=http://localhost:8086
INFLUXDB_ORG=SRB
INFLUXDB_BUCKET=srb_sensors

# Port série Arduino (Windows: COMx, Linux: /dev/ttyUSBx)
SERIAL_PORT=COM3

# Répertoire des logs (par défaut : ./logs)
SRB_LOG_DIR=logs
